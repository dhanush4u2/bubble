{
  "rewrites": [
    {
      "source": "/((?!_next|api|favicon\\.ico|robots\\.txt|placeholder\\.svg|assets/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
